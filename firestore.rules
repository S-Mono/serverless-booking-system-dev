rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 👑 管理者判定 (カスタムクレームをチェック)
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 👤 本人判定
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // 🔑 ログイン済み判定
    function isAuthenticated() {
      return request.auth != null;
    }

    // 📅 予約データ (reservations)
    match /reservations/{reservationId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
      allow create: if isOwner(request.resource.data.customer_id);
      allow update, delete: if isOwner(resource.data.customer_id);
    }

    // 📩 メッセージデータ (messages)
    match /messages/{messageId} {
      allow read, write: if isAdmin();
      allow read: if isOwner(resource.data.customer_id);
      allow create: if isOwner(request.resource.data.customer_id);
      allow update, delete: if isOwner(resource.data.customer_id);
    }

    // 📧 お問い合わせデータ (contacts)
    match /contacts/{contactId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // 👥 顧客データ (customers)
    match /customers/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isOwner(userId);
      allow get, list: if true;  // 電話番号ログイン用の検索を許可
      allow create: if isAuthenticated() && isOwner(userId);  // 新規ユーザー登録時の作成を許可
    }

    // 📋 マスタデータ
    match /menus/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /staffs/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /shop_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 🔔 通知トークン (admin_tokens)
    match /admin_tokens/{tokenId} {
      allow read, write: if isAdmin();
    }

    // 🏥 顧客カルテ (customer_medical_records) - 管理者のみ
    match /customer_medical_records/{document=**} {
      allow read, create, update, delete: if isAdmin();
    }

    // � パスワードリセットリクエスト
    match /password_reset_requests/{requestId} {
      // パスワードリセット機能のため、読み取りも許可
      allow read: if true;
      allow create: if true; // 誰でも作成可能（パスワード忘れ機能用）
      allow update: if true; // トークン使用済みフラグの更新用
    }

    // �🐛 エラーログ (error_logs) - 審査時のエラー収集用
    match /error_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;  // 誰でも書き込み可能（エラー発生時に記録するため）
    }
    // 🔍 【一時】LINE User ID ログ（確認後削除）
    match /tmp_line_uid_log/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated();
    }  }
}